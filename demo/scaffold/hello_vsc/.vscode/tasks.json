{
    // !!! don't use cmd.exe as default terminal
    "version": "2.0.0",
    "options": {
        "cwd": "${workspaceRoot}",
    },
    "windows": {
        // use this section for windeploy and qtDesigner
        "options": {
            "cwd": "${workspaceRoot}",
            "env": {
                // "PATH": "${env:PATH};D:/software/Qt/5.15.2/msvc2019_64/bin/;",
                "PATH": "${env:PATH};D:/software/Qt/6.2.4/msvc2019_64/bin/;",
            },
        },
    },
    "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false,
    },
    "problemMatcher": [],
    "tasks": [
        {
            "label": "Init",
            "type": "shell",
            "group": "none",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                // "-DCMAKE_PREFIX_PATH=D:/software/Qt/5.15.2/msvc2019_64",
                "-DCMAKE_PREFIX_PATH=D:/software/Qt/6.2.4/msvc2019_64",
                "-DCMAKE_CONFIGURATION_TYPES='Debug;Release;RelWithDebInfo;MinSizeRel'",
            ],
            "presentation": {
                "clear": true
            },
            "hide": true,
        },
        {
            "label": "Debug",
            "type": "shell",
            "group": "build",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug",
            ],
            "dependsOrder": "sequence",
            "dependsOn": [
                "Init"
            ],
            "hide": true,
        },
        {
            "label": "Release",
            "type": "shell",
            "group": "build",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Release",
            ],
            "dependsOrder": "sequence",
            "dependsOn": [
                "Init"
            ],
            "hide": true,
        },
        {
            "label": "vsJson",
            "detail": "parse compile_commands.json from vs sln file and build Debug",
            "type": "shell",
            "group": "build",
            "command": "./resources/vs_export.exe",
            "args": [
                "-s",
                "./build/${workspaceFolderBasename}.sln",
                "-c",
                "'Debug|x64'",
            ],
            "dependsOrder": "sequence",
            "dependsOn": [
                "Debug"
            ],
        },
        {
            "label": "Deploy",
            "detail": "run Qt windeploy",
            "type": "shell",
            "group": "build",
            "command": "windeployqt",
            "args": [
                "./build/Release/${workspaceFolderBasename}.exe"
            ],
            "dependsOrder": "sequence",
            "dependsOn": [
                "Release"
            ],
        },
        {
            "label": "QtDesigner",
            "detail": "open Qt ui file with QtDesigner",
            "type": "process",
            "group": "none",
            "command": "designer",
            "args": [
                "${relativeFile}"
            ],
            "presentation": {
                "echo": false,
                "showReuseMessage": false,
            },
        },
    ]
}
