    "version": "0.2.0",
    "configurations": [
        {
            "name": "runDebug",
            "type": "gdb",
            "request": "launch",
            "target": "./build/Debug/${workspaceFolderBasename}",
            "cwd": "${workspaceRoot}",
            "windows": {
                "env": {
                    "PATH": "${env:PATH};C:/Qt/Qt5/5.15.2/mingw81_64/bin/;C:/Qt/Qt5/Tools/mingw810_64/bin/;",
                    // "PATH": "${env:PATH};C:/Qt/Qt5/5.15.2/msvc2019_64/;C:/Qt/Qt5/5.15.2/msvc2019_64/bin/;",
                },
            },
            "valuesFormatting": "prettyPrinters",
            "preLaunchTask": "Debug",
            "internalConsoleOptions": "openOnSessionStart",
        }
    ]
}
