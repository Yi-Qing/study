{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "runDbg",
            "type": "cppvsdbg",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "program": "${workspaceFolder}/build/Debug/${workspaceFolderBasename}",
            "environment": [
                {
                    "name": "PATH",
                    // "value": "${env:PATH};D:/software/Qt/5.15.2/msvc2019_64/bin/;",
                    "value": "${env:PATH};D:/software/Qt/6.2.4/msvc2019_64/bin/;",
                }
            ],
            "preLaunchTask": "Debug",
            "internalConsoleOptions": "openOnSessionStart",
        },
    ]
}
