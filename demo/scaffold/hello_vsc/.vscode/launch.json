{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "runDebug",
            "type": "gdb",
            "request": "launch",
            "target": "${workspaceRoot}/build/Debug/${workspaceFolderBasename}",
            "cwd": "${workspaceRoot}",
            "windows": {
                "type": "cppvsdbg",
                "program": "${workspaceRoot}/build/Debug/${workspaceFolderBasename}.exe",
                "environment": [
                    {
                        "name": "PATH",
                        "value": "${env:PATH};C:/Users/Public/app/Qt/6.2.4/msvc2019_64/bin;",
                    }
                ],
            },
            "preLaunchTask": "Debug",
            "internalConsoleOptions": "openOnSessionStart"
        }
    ]
}
